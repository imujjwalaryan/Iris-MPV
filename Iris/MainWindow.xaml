<Window x:Class="Iris.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svgc="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        xmlns:local="clr-namespace:Iris"
        mc:Ignorable="d"
        Title="Iris" Height="550" Width="900"
        MinHeight="400" MinWidth="600"
        Background="#0e0e10"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        AllowDrop="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="80" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border x:Name="TitleBar" Grid.Row="0" Background="#1a1a1e">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: App Name -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Ellipse Width="10" Height="10"
                             Fill="MediumPurple"
                             Margin="0,0,10,0" />
                    <TextBlock x:Name="TitleBarText" Text="Iris"
                               Foreground="#e8e4dc"
                               FontSize="13"
                               FontWeight="Medium"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Right: Window controls -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch">

                    <Button x:Name="BtnMinimize" Content="-"
                            Style="{StaticResource TitleBarButton}" />

                    <Button x:Name="BtnMaximize" Content="□"
                            Style="{StaticResource TitleBarButton}" />

                    <Button x:Name="BtnClose" Content="✕"
                            Style="{StaticResource TitleBarCloseButton}" />

                </StackPanel>

            </Grid>
        </Border>

        <!-- Video Area -->
        <ContentControl x:Name="VideoArea" Grid.Row="1" Background="#000000" />

        <!-- Controls -->
        <Border Grid.Row="2" Background="#1a1a1e">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Seek bar row -->
                <Grid Grid.Row="0" Margin="16,8,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TxtCurrentTime" Grid.Column="0"
                               Text="0:00:00"
                               Foreground="{StaticResource MainAccentBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <Slider x:Name="SeekBar" Grid.Column="1"
                            Minimum="0" Maximum="100" Value="0"
                            VerticalAlignment="Center"
                            IsMoveToPointEnabled="True"
                            Style="{StaticResource SeekBarStyle}" />

                    <TextBlock x:Name="TxtDuration" Grid.Column="2"
                               Text="0:00:00"
                               Foreground="{StaticResource MainAccentBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </Grid>

                <!-- Buttons row -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left — empty -->
                    <StackPanel Grid.Column="0" />

                    <!-- Center — playback controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="BtnBack" Style="{StaticResource TitleBarButton}"
                                Width="48" Height="48" Margin="4,0">
                            <svgc:SvgViewbox Source="Assets/Icons/backward.svg"
                                             Width="20" Height="20" />
                        </Button>
                        <Button x:Name="BtnPlayPause" Style="{StaticResource TitleBarButton}"
                                Width="48" Height="48" Margin="4,0">
                            <svgc:SvgViewbox x:Name="IconPlayPause"
                                             Source="Assets/Icons/play.svg"
                                             Width="20" Height="20" />
                        </Button>
                        <Button x:Name="BtnForward" Style="{StaticResource TitleBarButton}"
                                Width="48" Height="48" Margin="4,0">
                            <svgc:SvgViewbox Source="Assets/Icons/forward.svg"
                                             Width="20" Height="20" />
                        </Button>
                    </StackPanel>

                    <!-- Right — volume -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnMute" Style="{StaticResource TitleBarButton}"
                                Width="48" Height="48" Margin="0,0,24,0">
                            <svgc:SvgViewbox x:Name="IconVolume"
                                             Source="Assets/Icons/volume.svg"
                                             Width="20" Height="20" />
                        </Button>
                    </StackPanel>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>